@model UpdateNotificationDto
@{
    ViewData["Title"] = "CreateNotification";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="content">
    <div class="container-fluid">
        <h4 class="page-title">Bildirim İşlemleri</h4>

        <div class="row">
            <div class="col-md-12">

                <form method="post">
                    <div class="card">

                        <div class="card-header">
                            <div class="card-title">Bildirim Güncelleme</div>
                        </div>

                        <div class="card-body">

                            <div class="form-group">
                                <input type="hidden" class="form-control" asp-for="NotificationId">
                            </div>

                            <div class="form-group">
                                <label>Bildirim Türü</label>
                                <input type="text" class="form-control" asp-for="Type">
                            </div>

                            <div class="form-group">
                                <label>Bildirim Icon</label>
                                <input type="text" class="form-control" asp-for="Icon">
                            </div>

                            <div class="form-group">
                                <label>Bildirim Açıklama</label>
                                <input type="text" class="form-control" asp-for="Description">
                            </div>

                        </div>

                        <div class="card-action">
                            <button class="btn btn-success">Bildirim Güncelle</button>
                        </div>

                    </div>
                </form>

            </div>
        </div>
    </div>
</div>
