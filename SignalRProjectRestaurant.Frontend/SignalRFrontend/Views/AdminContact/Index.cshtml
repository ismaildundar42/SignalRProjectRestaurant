@model List<ResultContactDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">İletişim İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<div class="card">
					<div class="card-header">
						<div class="card-title">İletişim Listesi</div>
					</div>
					<div class="card-body">

						<a href="/AdminContact/CreateContact/" class="btn btn-outline-primary">İletişim Ekle</a>

						<table class="table mt-3">
							<thead>
								<tr>
									<th scope="col">Telefon</th>
									<th scope="col">Açıklama</th>
									<th scope="col">Sil</th>
									<th scope="col">Güncelle</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var x in Model)
								{
									<tr>
										<td>@x.Phone</td>
										<td>@x.FooterDescription</td>
										<td><a href="/AdminContact/DeleteContact/@x.ContactId" class="btn btn-outline-danger">Sil</a></td>
										<td><a href="/AdminContact/EditContact/@x.ContactId" class="btn btn-outline-warning">Güncelle</a></td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>

			</div>

		</div>
	</div>
</div>




