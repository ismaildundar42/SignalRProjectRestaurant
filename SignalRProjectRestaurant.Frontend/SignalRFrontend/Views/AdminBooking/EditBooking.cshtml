@model UpdateBookingDto
@{
    ViewData["Title"] = "EditBooking";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Rezervasyon İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Rezervasyon Güncelleme</div>
						</div>
						<div class="card-body">

							<input type="hidden" asp-for="BookingId" class="form-control" />

							<div class="form-group">
								<label for="Name">Ad Soyad</label>
								<input type="text" class="form-control" id="Name" asp-for="Name">
								<span asp-validation-for="Name"></span>
							</div>

							<div class="form-group">
								<label for="Phone">Telefon</label>
								<input type="text" class="form-control" id="Phone" asp-for="Phone">
								<span asp-validation-for="Phone"></span>
							</div>

							<div class="form-group">
								<label for="Mail">Mail</label>
								<input type="email" class="form-control" id="Mail" asp-for="Mail">
								<span asp-validation-for="Mail"></span>
							</div>

							<div class="form-group">
								<label for="PersonCount">Kişi Sayısı</label>
								<input type="number" class="form-control" id="PersonCount" asp-for="PersonCount">
								<span asp-validation-for="PersonCount"></span>
							</div>

							<div class="form-group">
								<label for="Date">Rezervasyon Tarihi</label>
								<input type="date" class="form-control" id="Date" asp-for="Date">
								<span asp-validation-for="Date"></span>
							</div>

							<div class="card-action">
								<button class="btn btn-success">Rezervasyonu Güncelle</button>
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>





