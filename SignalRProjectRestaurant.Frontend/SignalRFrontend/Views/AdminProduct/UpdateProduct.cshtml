@model UpdateProductDto
@{
    ViewData["Title"] = "UpdateProduct";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}


<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Ürün İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Ürün Güncelleme</div>
						</div>
						<div class="card-body">


							<div class="form-group">
								<label for="ProductId">Ürün Id</label>
								<input type="hidden" class="form-control" id="ProductId" asp-for="ProductId">
							</div>

							<div class="form-group">
								<label for="ProductName">Ürün Adı</label>
								<input type="text" class="form-control" id="ProductName" asp-for="ProductName">
							</div>

							<div class="form-group">
								<label for="Price">Ürün Fiyatı</label>
								<input type="text" class="form-control" id="Price" asp-for="Price">
							</div>

							<div class="form-group">
								<label for="ImageUrl">Ürün Görseli</label>
								<input type="text" class="form-control" id="ImageUrl" asp-for="ImageUrl">
							</div>

							<div class="form-group">
								<label for="CategoryId">Ürün Kategorisi</label>
								@Html.DropDownListFor(x => x.CategoryId, (List<SelectListItem>)ViewBag.v1, new { @class = "form-control" })
							</div>

							<div class="form-group">
								<label for="Description">Ürün Açıklama</label>
								<input type="text" class="form-control" id="Description" asp-for="Description">
							</div>

							<div class="card-action">
								<button class="btn btn-success">Ürün Güncelle</button>
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>



