@model List<ResultProductDto>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
	int count = 0;
}

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Ürün İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<div class="card">
					<div class="card-header">
						<div class="card-title">Ürün Listesi</div>
					</div>
					<div class="card-body">

						<a href="/AdminProduct/CreateProduct/" class="btn btn-outline-primary">Ürün Ekle</a>

						<table class="table mt-3">
							<thead>
								<tr>
									<th scope="col">#</th>
									<th scope="col">Ad</th>
									<th scope="col">Kategori</th>
									<th scope="col">Fiyat</th>
									<th scope="col">Durum</th>
									<th scope="col">Sil</th>
									<th scope="col">Güncelle</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var x in Model)
								{
									count++;
									<tr>
										<th>@count</th>
										<td>@x.ProductName</td>
										<td>@x.CategoryName</td>
										<td>@x.Price</td>
										@if (x.ProductStatus == true)
										{
											<td>Aktif</td>
										}
										@if (x.ProductStatus == false)
										{
											<td>Pasif</td>
										}
										<td><a href="/AdminProduct/DeleteProduct/@x.ProductId" class="btn btn-outline-danger">Sil</a></td>
										<td><a href="/AdminProduct/UpdateProduct/@x.ProductId" class="btn btn-outline-warning">Güncelle</a></td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>

			</div>

		</div>
	</div>
</div>


