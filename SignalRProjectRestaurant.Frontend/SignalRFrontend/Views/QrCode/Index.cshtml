
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}




<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Qr Code İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form method="post" asp-controller="QrCode" asp-action="Index">
					<input type="text" name="value" />

					<input type="submit" class="btn btn-warning" value="Qr Code Oluştur" />

					<br />
					<br />

					@if (ViewBag.QrCodeImage != null)
					{
						<img src="@ViewBag.QrCodeImage" alt="" style="width:400px;height:400px" />
					}
				</form>
			</div>
		</div>
	</div>
</div>