@model LoginDto

@{
    Layout = null;
}

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap | Premium SignalR</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #4158D0 0%, #C850C0 46%, #FFCC70 100%);
            --glass-bg: rgba(255, 255, 255, 0.9);
        }

        body {
            background: var(--primary-gradient);
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            padding: 20px;
        }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 24px;
            padding: 3.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            width: 100%;
            max-width: 450px;
            transition: all 0.3s ease;
        }

        .header-section {
            text-align: center;
            margin-bottom: 2.5rem;
        }

            .header-section .brand-logo {
                width: 60px;
                height: 60px;
                background: #1a1a1a;
                color: white;
                border-radius: 16px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 1.5rem;
                font-size: 1.5rem;
                box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            }

            .header-section h2 {
                font-weight: 800;
                color: #1a1a1a;
                letter-spacing: -1px;
                margin-bottom: 0.5rem;
            }

        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: #4a4a4a;
            margin-left: 4px;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 1.25rem;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px 15px 12px 45px;
            border: 1.5px solid #e1e1e1;
            background: #f8f9fa;
            font-weight: 500;
            transition: all 0.2s ease;
        }

            .form-control:focus {
                background: #fff;
                border-color: #4158D0;
                box-shadow: 0 0 0 4px rgba(65, 88, 208, 0.1);
            }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #adb5bd;
            z-index: 10;
        }

        .btn-premium {
            background: #1a1a1a;
            color: white;
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            width: 100%;
            margin-top: 1rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

            .btn-premium:hover {
                background: #000;
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            }

        .footer-links {
            margin-top: 2rem;
            text-align: center;
            border-top: 1px solid #eee;
            padding-top: 1.5rem;
        }

        .checkbox-wrapper {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }
    </style>
</head>
<body>

    <div class="glass-card">
        <div class="header-section">
            <div class="brand-logo">
                <i class="fa-solid fa-signal"></i>
            </div>
            <h2>Tekrar Hoş Geldin</h2>
            <p class="text-muted small">Devam etmek için giriş yapın</p>
        </div>

        <form method="post">
            <label class="form-label">Kullanıcı Adı</label>
            <div class="input-group-custom">
                <i class="fa-regular fa-user input-icon"></i>
                <input type="text" class="form-control" asp-for="Username" placeholder="kullanici adi" required />
            </div>

            <label class="form-label">Şifre</label>
            <div class="input-group-custom">
                <i class="fa-solid fa-lock-open input-icon"></i>
                <input type="password" class="form-control" asp-for="Password" placeholder="••••••••" required />
            </div>

            <div class="checkbox-wrapper">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="rememberMe">
                    <label class="form-check-label small text-muted" for="rememberMe">Beni Hatırla</label>
                </div>
                <a href="#" class="small text-dark fw-semibold text-decoration-none">Şifremi Unuttum</a>
            </div>

            <button type="submit" class="btn btn-premium">Giriş Yap</button>

            <div class="footer-links">
                <p class="small text-muted mb-0">Hesabın yok mu? <a href="/Register/Index" class="text-dark fw-bold text-decoration-none">Hemen Kayıt Ol</a></p>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>