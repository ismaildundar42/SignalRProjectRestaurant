@model CreateDiscountDto
@{
    ViewData["Title"] = "CreateDiscount";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}



<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Günün İndirimi İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">İndirim Girişi</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<label for="Title">Ürün Adı</label>
								<input type="text" class="form-control" id="Title" asp-for="Title">
							</div>

							<div class="form-group">
								<label for="Amount">İndirim Oranı</label>
								<input type="text" class="form-control" id="Amount" asp-for="Amount">
							</div>

							<div class="form-group">
								<label for="Description">Açıklama</label>
								<input type="text" class="form-control" id="Description" asp-for="Description">
							</div>

							<div class="form-group">
								<label for="ImageUrl">Image Url</label>
								<input type="text" class="form-control" id="ImageUrl" asp-for="ImageUrl">
							</div>

							<div class="card-action">
								<button class="btn btn-success">İndirimi Ekle</button>
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

