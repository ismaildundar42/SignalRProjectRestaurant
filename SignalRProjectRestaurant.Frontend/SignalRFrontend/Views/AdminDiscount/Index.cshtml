@model List<ResultDiscountDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Günün İndirimi İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<div class="card">
					<div class="card-header">
						<div class="card-title">Günün İndirimleri</div>
					</div>
					<div class="card-body">

						<a href="/AdminDiscount/CreateDiscount/" class="btn btn-outline-primary">İndirim Ekle</a>

						<table class="table mt-3">
							<thead>
								<tr>
									<th scope="col">#</th>
									<th scope="col">Ürün</th>
									<th scope="col">İndirim Oranı</th>
									<th scope="col">Durum</th>
									<th scope="col">Sil</th>
									<th scope="col">Güncelle</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var x in Model)
								{
									<tr>
										<td>@x.DiscountId</td>
										<td>@x.Title</td>
										<td>@x.Amount</td>
										<td><a href="/AdminDiscount/EditDiscount/@x.DiscountId" class="btn btn-outline-primary">Durum Değiştir</a></td>
										<td><a href="/AdminDiscount/DeleteDiscount/@x.DiscountId" class="btn btn-outline-danger">Sil</a></td>
										<td><a href="/AdminDiscount/EditDiscount/@x.DiscountId" class="btn btn-outline-warning">Güncelle</a></td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>

			</div>

		</div>
	</div>
</div>


