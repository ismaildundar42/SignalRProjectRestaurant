@model List<ResultSliderDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Öne Çıkan Alan İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<div class="card">
					<div class="card-header">
						<div class="card-title">Öne Çıkan Alan Listesi</div>
					</div>
					<div class="card-body">

						<a href="/AdminSlider/CreateSlider/" class="btn btn-outline-primary">Öne Çıkan Alan Ekle</a>

						<table class="table mt-3">
							<thead>
								<tr>
									<th scope="col">#</th>
									<th scope="col">Başlık 1</th>
									<th scope="col">Açıklama 1</th>
									<th scope="col">Başlık 2</th>
									<th scope="col">Açıklama 2</th>
									<th scope="col">Başlık 3</th>
									<th scope="col">Açıklama 3</th>
									<th scope="col">Sil</th>
									<th scope="col">Güncelle</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var x in Model)
								{
									<tr>
										<td>@x.SliderId</td>
										<td>@x.Title1</td>
										<td>@x.Description1</td>
										<td>@x.Title2</td>
										<td>@x.Description2</td>
										<td>@x.Title3</td>
										<td>@x.Description3</td>
										<td><a href="/AdminSlider/DeleteSlider/@x.SliderId" class="btn btn-outline-danger">Sil</a></td>
										<td><a href="/AdminSlider/EditSlider/@x.SliderId" class="btn btn-outline-warning">Güncelle</a></td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>

			</div>

		</div>
	</div>
</div>


