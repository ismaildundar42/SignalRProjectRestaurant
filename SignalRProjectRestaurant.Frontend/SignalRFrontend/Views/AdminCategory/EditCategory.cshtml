@model SignalRFrontend.Dtos.CategoryDtos.UpdateCategoryDto
@{
    ViewData["Title"] = "EditCategory";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Kategori İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Kategori Güncelleme</div>
						</div>
						<div class="card-body">
							<div class="form-group">
								<input type="hidden" asp-for="CategoryId" />
								<label for="CategoryName">Kategori Adı</label>
								<input type="text" class="form-control" id="CategoryName" asp-for="CategoryName">
							</div>
							<div class="card-action">
								<button class="btn btn-success">Kategoriyi Güncelle</button>
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

