@model List<ResultMenuTableDto>
@{
	ViewData["Title"] = "MenuTableByStatus";
	Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
	string colour = "";
}

<div class="content">
    <div class="container-fluid">

		<h4 class="page-title">Anlık Masa Durumları Sayfası</h4>
		<div class="row">

			@foreach (var x in Model)
			{
				@if(@x.Status == false)
				{
					colour = "card card-stats card-danger";
				}
				@if (@x.Status == true)
				{
					colour = "card card-stats card-success";
				}
				<div class="col-md-3">
					<div class="@colour">
					<div class="card-body ">
						<div class="row">
							<div class="col-5">
								<div class="icon-big text-center">
									<i class="la la-certificate"></i>
								</div>
							</div>
							<div class="col-7 d-flex align-items-center">
								<div class="numbers">
									<p class="card-category">@x.Name</p>

									
										@if (@x.Status == false)
										{
											<h4 class="card-title">Boş</h4>
										}
										@if (@x.Status == true)
										{
											<h4 class="card-title">Dolu</h4>
										}
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			}
		</div>


	</div>
</div>