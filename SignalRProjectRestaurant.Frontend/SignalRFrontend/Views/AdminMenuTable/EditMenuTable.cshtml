@model UpdateMenuTableDto
@{
    ViewData["Title"] = "EditMenuTable";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Masa İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Masa Girişi</div>
						</div>
						<div class="card-body">
							<input type="hidden" asp-for="MenuTableId" />
							<div class="form-group">
								<label for="Location">Masa Adı</label>
								<input type="text" class="form-control" id="Location" asp-for="Name">
							</div>
							<div class="card-action">
								<button class="btn btn-success">Masa Güncelle</button>
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>







