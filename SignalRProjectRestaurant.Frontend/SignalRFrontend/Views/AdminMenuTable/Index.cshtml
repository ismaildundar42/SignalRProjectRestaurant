@model List<ResultMenuTableDto>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
	int count = 0;
}

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Masa İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<div class="card">
					<div class="card-header">
						<div class="card-title">Masa Listesi</div>
					</div>
					<div class="card-body">

						<a href="/AdminMenuTable/CreateMenuTable/" class="btn btn-outline-primary">Masa Ekle</a>

						<table class="table mt-3">
							<thead>
								<tr>
									<th scope="col">#</th>
									<th scope="col">Masa Ad</th>
									<th scope="col">Sil</th>
									<th scope="col">Güncelle</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var x in Model)
								{
									count++;
									<tr>
										<th>@count</th>
										<td>@x.Name</td>
										<td><a href="/AdminMenuTable/DeleteMenuTable/@x.MenuTableId" class="btn btn-outline-danger">Sil</a></td>
										<td><a href="/AdminMenuTable/EditMenuTable/@x.MenuTableId" class="btn btn-outline-warning">Güncelle</a></td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>

			</div>

		</div>
	</div>
</div>






