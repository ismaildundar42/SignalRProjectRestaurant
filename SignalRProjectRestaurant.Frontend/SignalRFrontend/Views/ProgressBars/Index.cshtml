@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

	<script type="text/javascript">
		$(document).ready(() => {
			// SignalR bağlantısı
			var connection = new signalR.HubConnectionBuilder().withUrl("https://localhost:7014/SignalRHub").build();

			$("#connStatus").text(connection.state);

			// Önce tüm listener'ları tanımla (connection.start() öncesinde)
			connection.on("ReceiveTotalMoneyCaseAmount", (value) => {
				$("#kasaToplamTutar").text(value);
			});

			connection.on("ReceiveLastOrderPrice", (value2) => {
				$("#sonSiparisTutar").text(value2);
			});

			connection.on("ReceiveActiveOrderCount", (value3) => {
				$("#aktifSiparisSayisi").text(value3);
			});

			connection.on("ReceiveMenuTableCount", function(value4) {

				var htmlContent = '<div class="d-flex justify-content-between mb-1">' +
					'<span class="text-muted">Toplam Masa Sayısı</span>' +
					'<span class="text-muted fw-bold">' + value4 + '</span>' +
					'</div>' +
					'<div class="progress mb-2" style="height: 7px;">' +
					'<div class="progress-bar bg-success" role="progressbar" ' +
					'style="width: ' + value4 + '%;" ' +
					'aria-valuenow="' + value4 + '" aria-valuemin="0" aria-valuemax="100" ' +
					'title="' + value4 + '%"></div>' +
					'</div>';

				$("#totalMenuTableCountProgress").html(htmlContent);
			});

			connection.on("ReceiveProductPriceAvg", function(value5) {

				var htmlContent = '<div class="d-flex justify-content-between mb-1">' +
					'<span class="text-muted">Ortalama Ürün Fiyatı</span>' +
					'<span class="text-muted fw-bold">' + value5 + '</span>' +
					'</div>' +
					'<div class="progress mb-2" style="height: 7px;">' +
					'<div class="progress-bar bg-info" role="progressbar" ' +
					'style="width: ' + value5 + '%;" ' +
					'aria-valuenow="' + value5 + '" aria-valuemin="0" aria-valuemax="100" ' +
					'title="' + value5 + '%"></div>' +
					'</div>';

				$("#ReceiveProductPriceAvg").html(htmlContent);
			});

			connection.on("ReceiveAvgPriceByFirin", function(value6) {

				var htmlContent = '<div class="d-flex justify-content-between mb-1">' +
					'<span class="text-muted">Ortalama Fırın Ürünü Fiyatı</span>' +
					'<span class="text-muted fw-bold">' + value6 + '</span>' +
					'</div>' +
					'<div class="progress mb-2" style="height: 7px;">' +
					'<div class="progress-bar bg-primary" role="progressbar" ' +
					'style="width: ' + value6 + '%;" ' +
					'aria-valuenow="' + value6 + '" aria-valuemin="0" aria-valuemax="100" ' +
					'title="' + value6 + '%"></div>' +
					'</div>';

				$("#ReceiveAvgPriceByFirin").html(htmlContent);
			});

			connection.on("ReceiveDrinkCount", function(value7) {

				var htmlContent = '<div class="d-flex justify-content-between mb-1">' +
					'<span class="text-muted">Toplam İçecek Sayısı</span>' +
					'<span class="text-muted fw-bold">' + value7 + '</span>' +
					'</div>' +
					'<div class="progress mb-2" style="height: 7px;">' +
					'<div class="progress-bar bg-warning" role="progressbar" ' +
					'style="width: ' + value7 + '%;" ' +
					'aria-valuenow="' + value7 + '" aria-valuemin="0" aria-valuemax="100" ' +
					'title="' + value7 + '%"></div>' +
					'</div>';

				$("#ReceiveDrinkCount").html(htmlContent);
			});

			connection.on("ReceiveTotalOrderCount", function(value8) {

				var htmlContent = '<div class="d-flex justify-content-between mb-1">' +
					'<span class="text-muted">Toplam Sipariş Sayısı</span>' +
					'<span class="text-muted fw-bold">' + value8 + '</span>' +
					'</div>' +
					'<div class="progress mb-2" style="height: 7px;">' +
					'<div class="progress-bar bg-primary" role="progressbar" ' +
					'style="width: ' + value8 + '%;" ' +
					'aria-valuenow="' + value8 + '" aria-valuemin="0" aria-valuemax="100" ' +
					'title="' + value8 + '%"></div>' +
					'</div>';

				$("#ReceiveTotalOrderCount").html(htmlContent);
			});

			connection.on("TotalPriceByIcecekCategory", function(value9) {

				var htmlContent = '<div class="d-flex justify-content-between mb-1">' +
					'<span class="text-muted">İçecek Kategorisi Toplam Fiyatı</span>' +
					'<span class="text-muted fw-bold">' + value9 + '</span>' +
					'</div>' +
					'<div class="progress mb-2" style="height: 7px;">' +
					'<div class="progress-bar bg-success" role="progressbar" ' +
					'style="width: ' + value9 + '%;" ' +
					'aria-valuenow="' + value9 + '" aria-valuemin="0" aria-valuemax="100" ' +
					'title="' + value9 + '%"></div>' +
					'</div>';

				$("#TotalPriceByIcecekCategory").html(htmlContent);
			});

			// Sonra bağlantıyı başlat
			connection.start().then(() => {
				$("#connStatus").text(connection.state);

				setInterval(() => {
					connection.invoke("SendProgress");
				}, 1000);

			}).catch((err) => { console.log(err) });
		});
	</script>
	}

@* <div class="d-flex justify-content-between mb-1">
	<span class="text-muted">Profit</span>
	<span class="text-muted fw-bold"> $3K</span>
</div>
<div class="progress mb-2" style="height: 7px;">
	<div class="progress-bar bg-success" role="progressbar" style="width: 78%" aria-valuenow="78" aria-valuemin="0" aria-valuemax="100" data-toggle="tooltip" data-placement="top" title="78%"></div>
</div> *@

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Admin İstatistikler & Durumlar</h4>
		<div class="row">
			<div class="col-md-12">

				<div class="row row-card-no-pd">
					<div class="col-md-4">
						<div class="card">
							<div class="card-body">
								<p class="fw-bold mt-1">Kasadaki Toplam Tutar</p>
								<h4 id="kasaToplamTutar"><b></b></h4>
								<a href="#" class="btn btn-primary btn-full text-left mt-3 mb-3"><i class="la la-plus"></i> Yeni Sipariş Oluştur</a>
							</div>
							<div class="card-footer">
								<ul class="nav">
									<li class="nav-item"><a class="btn btn-default btn-link" href="#"><i class="la la-history"></i> Siparişler</a></li>
									<li class="nav-item ml-auto"><a class="btn btn-default btn-link" href="/ProgressBars/Index/"><i class="la la-refresh"></i> Sayfayı Yenile</a></li>
								</ul>
							</div>
						</div>
					</div>
					<div class="col-md-5">
						<div class="card">
							<div class="card-body">
								<div class="progress-card" id="totalMenuTableCountProgress"></div>

								<div class="progress-card" id="ReceiveProductPriceAvg"></div>

								<div class="progress-card" id="ReceiveAvgPriceByFirin"></div>

								<div class="progress-card" id="ReceiveDrinkCount"></div>

								<div class="progress-card" id="ReceiveTotalOrderCount"></div>

								<div class="progress-card" id="TotalPriceByIcecekCategory"></div>
							</div>
						</div>
					</div>
					<div class="col-md-3">
						<div class="card card-stats">
							<div class="card-body">
								<p class="fw-bold mt-1">Sipariş İstatistiği</p>
								<div class="row">
									<div class="col-5">
										<div class="icon-big text-center icon-warning">
											<i class="la la-pie-chart text-warning"></i>
										</div>
									</div>
									<div class="col-7 d-flex align-items-center">
										<div class="numbers">
											<p class="card-category">Son Sipariş Tutarı</p>
											<h4 class="card-title" id="sonSiparisTutar"></h4>
										</div>
									</div>
								</div>
								<hr />
								<div class="row">
									<div class="col-5">
										<div class="icon-big text-center">
											<i class="la la-heart-o text-primary"></i>
										</div>
									</div>
									<div class="col-7 d-flex align-items-center">
										<div class="numbers">
											<p class="card-category">Aktif Sipariş Sayısı</p>
											<h4 class="card-title" id="aktifSiparisSayisi"></h4>
										</div>
									</div>
								</div>

								<hr />
								<div class="row">
									<div class="col-5">
										<div class="icon-big text-center">
											<i class="la la-car text-success"></i>
										</div>
									</div>
									<div class="col-7 d-flex align-items-center">
										<div class="numbers">
											<p class="card-category">Kategori Sayısı</p>
											<h4 class="card-title">30</h4>
										</div>
									</div>
								</div>

								<hr />
								<div class="row">
									<div class="col-5">
										<div class="icon-big text-center">
											<i class="la la-dribbble text-danger"></i>
										</div>
									</div>
									<div class="col-7 d-flex align-items-center">
										<div class="numbers">
											<p class="card-category">Ürün Sayısı</p>
											<h4 class="card-title">25</h4>
										</div>
									</div>
								</div>

								<hr />
								<div class="row">
									<div class="col-5">
										<div class="icon-big text-center">
											<i class="la la-glass text-dark"></i>
										</div>
									</div>
									<div class="col-7 d-flex align-items-center">
										<div class="numbers">
											<p class="card-category">Rezervasyon Sayısı</p>
											<h4 class="card-title">44</h4>
										</div>
									</div>
								</div>

							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

