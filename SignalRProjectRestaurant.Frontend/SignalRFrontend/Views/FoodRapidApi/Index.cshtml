@model List<ResultTastyApiDto>

@{
    ViewData["Title"] = "Index";
    Layout = null;
}

<!DOCTYPE html>
<html>

@await Component.InvokeAsync("_UiLayoutHeadVC")

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<body class="sub_page">

    @await Component.InvokeAsync("_MenuNavbarVC")

    <br />
    <br />
    <div class="container-fluid">
        <div class="row px-xl-5">
            <div class="col-12">
                <nav class="breadcrumb bg-dark mb-30">
                    <a class="breadcrumb-item text-white" href="/Default/Index/">Anasayfa</a>
                    <a class="breadcrumb-item text-white" href="/Menu/Index/">API Listesi</a>
                    <span class="breadcrumb-item active">Tasty Api</span>
                </nav>
            </div>
        </div>
    </div> 

    <div class="container-fluid">
        <div class="row px-xl-5">
            <div class="col-lg-12 table-responsive mb-5">
                <table class="table table-light table-borderless table-hover text-center mb-0">
                    <thead class="thead-dark">
                        <tr>
                            <th>#</th>
                            <th>Ürün Adı</th>
                            <th>Video Url</th>
                        </tr>
                    </thead>
                    @foreach(var x in Model)
                    {
                        <tr>
                            <td><img src="@x.thumbnail_url" style="width:50px;height:50px" /></td>
                            <td>@x.name</td>
                            <td><a href="@x.video_url" target="_blank" class="btn btn-sm btn-warning rounded-pill px-3">Tarifi İzle</a></td>
                        </tr>
                    }
                </table>
            </div>
           

        </div>
    </div>

    @await Component.InvokeAsync("_UiLayoutFooterVC")
    @await Component.InvokeAsync("_UiLayoutScriptsVC")



</body>

</html>



