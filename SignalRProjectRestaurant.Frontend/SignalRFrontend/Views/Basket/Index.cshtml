@model List<ResultBasketDto>
@{
    Layout = null;
    int count = 0;
    decimal basketTotalPrice = 0;
}

<!DOCTYPE html>
<html>

@await Component.InvokeAsync("_UiLayoutHeadVC")

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<body class="sub_page">

    @await Component.InvokeAsync("_MenuNavbarVC")

    <br />
    <br />
    <div class="container-fluid">
        <div class="row px-xl-5">
            <div class="col-12">
                <nav class="breadcrumb bg-dark mb-30">
                    <a class="breadcrumb-item text-white" href="/Default/Index/">Anasayfa</a>
                    <a class="breadcrumb-item text-white" href="/Menu/Index/">Menü</a>
                    <span class="breadcrumb-item active">Sepetiniz</span>
                </nav>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row px-xl-5">
            <div class="col-lg-8 table-responsive mb-5">  
                <table class="table table-light table-borderless table-hover text-center mb-0"> 
                    <thead class="thead-dark">
                        <tr>
                            <th>#</th>
                            <th>Ürün Adı</th>
                            <th>Fiyat</th>
                            <th>Adet</th>
                            <th>Toplam</th>
                            <th>Sil</th>
                        </tr>
                    </thead>
                    @foreach(var x in Model)
                    {
                        basketTotalPrice = Model.Sum(x => x.Price);
                        count++;
                        <tbody class="align-middle">
                            <tr>
                            <td class="align-middle">@count</td>
                            <td class="align-middle">@x.ProductName</td>
                            <td class="align-middle">@x.Price</td>
                            <td class="align-middle">@x.Count</td>
                            <td class="align-middle">@x.TotalPrice</td>
                                <td class="align-middle btn-delete">
                                    <button data-basketid="@x.BasketId" id="btndeletebasketid" class="btn btn-sm btn-danger">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </td>

                            </tr>
                    </tbody>
                    }
                </table>
            </div>
            <div class="col-lg-4">
                <form>
                    <div class="input-group">
                        <input type="text" id="couponcode" class="form-control p-4" placeholder="Kupon Kodunuz" />
                        <button type="button" class="btn btn-warning" id="btncouponcode" style="height: 48px; padding-top: 14px;margin-left: 10px;">Kuponu Uygula</button>
                    </div>
                </form>
                <br />
                <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-warning pr-3">Sepet Özeti</span></h5>
                <div class="bg-light p-30 mb-5">
                    <div id="container" class="border-bottom pb-2">
                        <div class="d-flex justify-content-between mb-3">
                            <h6>Toplam Tutar</h6>
                            <h6><span id="totalprice">@basketTotalPrice</span>₺</h6>
                        </div>
                    </div>
                    <br />
                    <button id="checked" class="btn btn-block btn-warning font-weight-bold my-3">
                        Siparişi Tamamla
                    </button>
                </div>
            </div>

        </div>
    </div>

    @await Component.InvokeAsync("_UiLayoutFooterVC")
    @await Component.InvokeAsync("_UiLayoutScriptsVC")

   
    
</body>

</html>

