@model List<ResultBasketDto>
@{
    Layout = null;
    int count = 0;
}

<!DOCTYPE html>
<html>

@await Component.InvokeAsync("_UiLayoutHeadVC")

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<body class="sub_page">

    @await Component.InvokeAsync("_MenuNavbarVC")

    <br />
    <br />
    <div class="container-fluid">
        <div class="row px-xl-5">
            <div class="col-12">
                <nav class="breadcrumb bg-dark mb-30">
                    <a class="breadcrumb-item text-white" href="/Default/Index/">Anasayfa</a>
                    <a class="breadcrumb-item text-white" href="/Menu/Index/">Menü</a>
                    <span class="breadcrumb-item active">Sepetiniz</span>
                </nav>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row px-xl-5">
            <div class="col-lg-8 table-responsive mb-5">  
                <table class="table table-light table-borderless table-hover text-center mb-0"> 
                    <thead class="thead-dark">
                        <tr>
                            <th>#</th>
                            <th>Ürün Adı</th>
                            <th>Fiyat</th>
                            <th>Adet</th>
                            <th>Toplam</th>
                            <th>Sil</th>
                        </tr>
                    </thead>
                    @foreach(var x in Model)
                    {
                        count++;
                        <tbody class="align-middle">
                            <tr>
                            <td class="align-middle">@count</td>
                            <td class="align-middle">@x.ProductId</td>
                            <td class="align-middle">@x.Price</td>
                            <td class="align-middle">@x.Count</td>
                            <td class="align-middle">@x.TotalPrice</td>
                                <td class="align-middle btn-delete">
                                    <button data-basketid="@x.BasketId" id="btndeletebasketid" class="btn btn-sm btn-danger">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </td>

                            </tr>
                    </tbody>
                    }
                </table>
            </div>
        </div>
    </div>

    @await Component.InvokeAsync("_UiLayoutFooterVC")
    @await Component.InvokeAsync("_UiLayoutScriptsVC")

   
    
</body>

</html>

