@model List<ResultTestimonialDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Referans İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<div class="card">
					<div class="card-header">
						<div class="card-title">Referans Listesi</div>
					</div>
					<div class="card-body">

						<a href="/AdminTestimonial/CreateTestimonial/" class="btn btn-outline-primary">Referans Ekle</a>

						<table class="table mt-3">
							<thead>
								<tr>
									<th scope="col">#</th>
									<th scope="col">Ad Soyad</th>
									<th scope="col">Durum</th>
									<th scope="col">Sil</th>
									<th scope="col">Güncelle</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var x in Model)
								{
									<tr>
										<td>@x.TestimonialId</td>
										<td>@x.Name</td>
										@if (x.Status == true)
										{
											<td>Aktif</td>
										}
										@if (x.Status == false)
										{
											<td>Pasif</td>
										}
										<td><a href="/AdminTestimonial/DeleteTestimonial/@x.TestimonialId" class="btn btn-outline-danger">Sil</a></td>
										<td><a href="/AdminTestimonial/EditTestimonial/@x.TestimonialId" class="btn btn-outline-warning">Güncelle</a></td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				</div>

			</div>

		</div>
	</div>
</div>


