@model CreateTestimonialDto
@{
    ViewData["Title"] = "CreateTestimonial";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}


<div class="content">
	<div class="container-fluid">
		<h4 class="page-title">Referans İşlemleri</h4>
		<div class="row">
			<div class="col-md-12">
				<form method="post">
					<div class="card">
						<div class="card-header">
							<div class="card-title">Referans Girişi</div>
						</div>
						<div class="card-body">


							<div class="form-group">
								<label for="Name">Ad Soyad</label>
								<input type="text" class="form-control" id="Name" asp-for="Name">
							</div>

							<div class="form-group">
								<label for="Title">Unvan</label>
								<input type="text" class="form-control" id="Title" asp-for="Title">
							</div>

							<div class="form-group">
								<label for="ImageUrl">Image Url</label>
								<input type="text" class="form-control" id="ImageUrl" asp-for="ImageUrl">
							</div>

							<div class="form-group">
								<label for="Comment">Yorum</label>
								<textarea asp-for="Comment" class="form-control" rows="3"></textarea>
							</div>

							<div class="card-action">
								<button class="btn btn-success">Yorumu Ekle</button>
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

